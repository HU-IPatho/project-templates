# ============================================================================
# data/ ツリーは git 非追跡（サイズ・バイナリ・provenance 統制）。
# ただし 3 層ディレクトリ構造は .gitkeep で残す。永続/共有は work-save/work-share。
# outputs/ と reports/ は追跡する（成果物を PR/diff でレビュー可能に）。
# ============================================================================
/data/**
!/data/
!/data/raw/
!/data/interim/
!/data/processed/
!/data/**/.gitkeep

# バイナリ中間物（data/ 外に誤って置いた場合の保険）
*.rds
*.tar
*.tar.gz
*.h5
*.h5ad

# R / renv（library 本体は追跡しない。renv.lock と activate.R は追跡する）
.Rhistory
.RData
.Rproj.user/
renv/library/
renv/staging/
renv/cellar/
renv/local/
renv/lock/
renv/python/
renv/sandbox/

# Python
__pycache__/
*.pyc
.venv/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
