# ============================================================================
# analysis-template-standard 準拠の追跡ポリシー
#   - data/ の中身（生データ・中間・処理済 object）は git 非追跡（サイズ/バイナリ/provenance）
#     永続・共有は work-save / work-share（HDD 二層分離）が担う。
#   - 3 層の空ディレクトリ構造は .gitkeep で保持する（下の否定パターン）。
#   - outputs/ と reports/ は追跡する（成果物を PR/diff でレビュー可能に）。
# ============================================================================

# --- data/ の中身は非追跡。ただし 3 層の .gitkeep は残す ---
data/**
!data/raw/
!data/raw/.gitkeep
!data/interim/
!data/interim/.gitkeep
!data/processed/
!data/processed/.gitkeep

# 念のため代表的な大容量/バイナリ成果物（data 配下に限らず）
*.rds
*.h5
*.h5ad
*.bam
*.tar
*.tar.gz

# --- R / renv（library 本体は追跡しない。renv.lock は追跡する）---
.Rhistory
.RData
.Rproj.user/
renv/library/
renv/staging/
renv/cellar/
renv/local/
renv/python/
renv/sandbox/

# --- Python ---
__pycache__/
*.pyc
.venv/

# --- Quarto ---
/.quarto/
reports/*_files/

# --- OS / IDE ---
.DS_Store
Thumbs.db
