# ============================================================================
# data/ は git 非追跡（サイズ・バイナリ・provenance 統制。永続/共有は work-save/work-share）
# 3 層ディレクトリ構造だけは .gitkeep で残す（中身＝FASTQ/中間物/rds は追跡しない）
# ============================================================================
/data/**
!/data/
!/data/raw/
!/data/interim/
!/data/processed/
!/data/**/.gitkeep

# 大容量・バイナリ生成物（どこに出ても追跡しない）
*.rds
*.bam
*.sam
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.sf
*.h5
*.h5ad

# R / renv（library 本体は追跡しない。renv.lock と activate.R / settings.json は追跡する）
.Rhistory
.RData
.Rproj.user/
renv/library/
renv/staging/
renv/cellar/
renv/local/
renv/lock/
renv/python/
renv/sandbox/

# Python
__pycache__/
*.pyc
.venv/

# Quarto レンダリング中間物（reports の *.html は追跡する）
/reports/*_files/
/reports/.quarto/
.quarto/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
